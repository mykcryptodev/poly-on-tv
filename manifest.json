{
  "manifest_version": 3,
  "name": "Polymarket Odds for YouTube TV",
  "version": "2.5.0",
  "description": "Display live Polymarket odds on YouTube TV",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://tv.youtube.com/*"],
      "js": ["src/content/content-script-simple.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/iframe-widget.html", "src/content/iframe-widget.js"],
      "matches": ["https://tv.youtube.com/*"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
